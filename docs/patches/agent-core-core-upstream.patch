+                continue;
+            }
+            outbound = outbound.set(&key, &value);
+        }
+        let response = match request.body {
+            Some(HttpBody::Json(value)) => outbound.send_json(value),
+            Some(HttpBody::Bytes(value)) => outbound.send_bytes(&value),
+            None => outbound.call(),
+        };
