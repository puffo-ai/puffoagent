+fn read_single_http_request(listener: TcpListener) -> String {
+    let (mut stream, _) = listener.accept().unwrap();
+    stream
+        .set_read_timeout(Some(Duration::from_secs(2)))
+        .unwrap();
+    let mut bytes = Vec::new();
+    let mut chunk = [0_u8; 1024];
+    loop {
+        let read = stream.read(&mut chunk).unwrap();
+        if read == 0 {
+            break;
+        }
+        bytes.extend_from_slice(&chunk[..read]);
+        if complete_http_request(&bytes) {
+            break;
+        }
+    }
+    let response_body = r#"{"ok":true}"#;
+    write!(
+        stream,
+        "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: {}\r\nConnection: close\r\n\r\n{}",
+        response_body.len(),
+        response_body
+    )
+    .unwrap();
+    String::from_utf8(bytes).unwrap()
+}
+
+fn complete_http_request(bytes: &[u8]) -> bool {
+    let Some(header_start) = bytes.windows(4).position(|window| window == b"\r\n\r\n") else {
+        return false;
+    };
+    let header_end = header_start + 4;
+    let headers = String::from_utf8_lossy(&bytes[..header_start]);
+    let content_length = headers
+        .lines()
+        .find_map(|line| {
+            let (name, value) = line.split_once(':')?;
+            if name.eq_ignore_ascii_case("content-length") {
+                value.trim().parse::<usize>().ok()
+            } else {
+                None
+            }
+        })
+        .unwrap_or(0);
+    bytes.len() >= header_end + content_length
+}
