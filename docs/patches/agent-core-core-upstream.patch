+#[test]
+fn blocking_http_transport_sends_json_and_decodes_json_response() {
+    let listener = TcpListener::bind("127.0.0.1:0").unwrap();
+    let api_url = format!("http://{}", listener.local_addr().unwrap());
+    let server = std::thread::spawn(move || read_single_http_request(listener));
+
+    let request = HttpRequest::new(HttpMethod::Post, "/v1/echo")
+        .query("q", "hello world")
+        .header("x-puffo-api-url", api_url)
+        .json(&serde_json::json!({ "hello": "world" }))
+        .unwrap();
+    let response = BlockingHttpTransport::default().send(request).unwrap();
+
+    assert_eq!(response.status, 200);
+    assert_eq!(
+        response.body,
+        Some(HttpBody::Json(serde_json::json!({ "ok": true })))
+    );
+    let raw_request = server.join().unwrap();
+    assert!(
+        raw_request.starts_with("POST /v1/echo?q=hello%20world HTTP/1.1"),
+        "{raw_request}"
+    );
+    assert!(
+        raw_request.contains("content-type: application/json")
+            || raw_request.contains("Content-Type: application/json")
+    );
+    assert!(
+        raw_request.contains(r#"{"hello":"world"}"#),
+        "{raw_request}"
+    );
+    assert!(!raw_request.contains("x-puffo-api-url"), "{raw_request}");
+}
